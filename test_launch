#!/usr/bin/env python3
import subprocess
import sys
import os
import signal
import atexit
import time

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
PUBLIC_HTML = os.path.join(SCRIPT_DIR, "public_html")
SERVICE_DIR = os.path.join(SCRIPT_DIR, "service")

STATIC_PORT = 60193
SERVICE_PORT = 3000

processes = []

def pids_on_port(port):
    try:
        out = subprocess.run(
            ["lsof", "-ti", f"tcp:{port}"],
            capture_output=True, text=True, check=False,
        ).stdout.strip()
    except FileNotFoundError:
        return []
    return [int(pid) for pid in out.splitlines() if pid]

def free_port(port, label):
    pids = pids_on_port(port)
    if not pids:
        return
    print(f"Port {port} ({label}) already in use by PID(s) {', '.join(map(str, pids))} — killing.")
    for pid in pids:
        try:
            os.kill(pid, signal.SIGTERM)
        except ProcessLookupError:
            pass
    deadline = time.time() + 5
    while time.time() < deadline and pids_on_port(port):
        time.sleep(0.2)
    for pid in pids_on_port(port):
        try:
            os.kill(pid, signal.SIGKILL)
        except ProcessLookupError:
            pass

def cleanup():
    for p in processes:
        try:
            p.terminate()
        except ProcessLookupError:
            pass
    for p in processes:
        try:
            p.wait(timeout=5)
        except subprocess.TimeoutExpired:
            p.kill()

def handle_signal(sig, frame):
    print("\nShutting down...")
    cleanup()
    sys.exit(0)

atexit.register(cleanup)
signal.signal(signal.SIGINT, handle_signal)
signal.signal(signal.SIGTERM, handle_signal)

free_port(STATIC_PORT, "static file server")
free_port(SERVICE_PORT, "Node.js service")

print(f"Starting static file server on http://localhost:{STATIC_PORT} (serving {PUBLIC_HTML})")
static_server = subprocess.Popen(
    [sys.executable, "-m", "http.server", str(STATIC_PORT), "--directory", PUBLIC_HTML],
)
processes.append(static_server)

print(f"Starting Node.js service on port {SERVICE_PORT} (serving /service from {SERVICE_DIR})")
node_proc = subprocess.Popen(
    ["node", "app.js"],
    cwd=SERVICE_DIR,
)
processes.append(node_proc)

print("Both servers running. Press Ctrl+C to stop.")
print(f"  Static pages: http://localhost:{STATIC_PORT}")
print(f"  Node service: http://localhost:{SERVICE_PORT}/service")

# Wait for either process to exit
try:
    while True:
        for p in processes:
            ret = p.poll()
            if ret is not None:
                name = "Static server" if p == static_server else "Node service"
                print(f"{name} exited with code {ret}. Shutting down.")
                sys.exit(ret)
        time.sleep(1)
except KeyboardInterrupt:
    pass
