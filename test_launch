#!/usr/bin/env python3
import subprocess
import sys
import os
import signal
import atexit

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
PUBLIC_HTML = os.path.join(SCRIPT_DIR, "public_html")
SERVICE_DIR = os.path.join(SCRIPT_DIR, "service")

processes = []

def cleanup():
    for p in processes:
        try:
            p.terminate()
        except ProcessLookupError:
            pass
    for p in processes:
        try:
            p.wait(timeout=5)
        except subprocess.TimeoutExpired:
            p.kill()

def handle_signal(sig, frame):
    print("\nShutting down...")
    cleanup()
    sys.exit(0)

atexit.register(cleanup)
signal.signal(signal.SIGINT, handle_signal)
signal.signal(signal.SIGTERM, handle_signal)

print(f"Starting static file server on http://localhost:60193 (serving {PUBLIC_HTML})")
static_server = subprocess.Popen(
    [sys.executable, "-m", "http.server", "60193", "--directory", PUBLIC_HTML],
)
processes.append(static_server)

print(f"Starting Node.js service on port 3000 (serving /service from {SERVICE_DIR})")
node_proc = subprocess.Popen(
    ["node", "app.js"],
    cwd=SERVICE_DIR,
)
processes.append(node_proc)

print("Both servers running. Press Ctrl+C to stop.")
print("  Static pages: http://localhost:60193")
print("  Node service: http://localhost:3000/service")

# Wait for either process to exit
try:
    while True:
        for p in processes:
            ret = p.poll()
            if ret is not None:
                name = "Static server" if p == static_server else "Node service"
                print(f"{name} exited with code {ret}. Shutting down.")
                sys.exit(ret)
        import time
        time.sleep(1)
except KeyboardInterrupt:
    pass
